---
import './base.css';
import './tabs.css';
import faviconSvg from './favicon.svg?url';
import photoPreviewJs from './photo-preview.js?url';
import PageHeader from './PageHeader.astro';
import PageFooter from './PageFooter.astro';

interface Props {
  project: string;
  title: string;
  sciences: string[];
  mi?: boolean;
  htmlLang?: string;
  photos?: string[];
}

const {
  project,
  title,
  sciences,
  mi = false,
  htmlLang = 'en',
  photos = [],
} = Astro.props;

// Full → short slug for chip class names. Same map used by toys.json.
const SLUG: Record<string, string> = {
  Mathematics: 'math', Computing: 'comp', Physics: 'phys',
  Chemistry: 'chem', Biology: 'bio', Astronomy: 'astro',
};
---
<!DOCTYPE html>
<html lang={htmlLang}>
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <link rel="icon" type="image/svg+xml" href={faviconSvg} />
  <title>{project || title || 'Vivian Dai'}</title>
  <script is:inline set:html={`window._pagePhotos = ${JSON.stringify(photos)};`} />
  <style is:global>
    /* Project layout specific styles */
    .photo-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 0.5em;
      margin: 1em 0 0.5em 0;
    }
    .photo-grid img {
      width: 100%;
      height: 200px;
      object-fit: cover;
      border-radius: 6px;
    }
    .photo-grid.three-col {
      grid-template-columns: 1fr 1fr 1fr;
    }
    .shuffle-btn {
      display: block;
      margin: 0 auto 1.5em auto;
      padding: 0.4em 1.2em;
      border: 1px solid #d1d9e0;
      border-radius: 6px;
      background: #f6f8fa;
      color: #1f2328;
      font-size: 0.85em;
      cursor: pointer;
      transition: background 0.15s, border-color 0.15s;
    }
    .shuffle-btn:hover {
      background: #ddf4ff;
      border-color: #0969da;
    }
    .hero-single img {
      width: 100%;
      height: 250px;
      object-fit: cover;
      border-radius: 6px;
      margin: 1em 0 0.5em 0;
    }
    .project-meta {
      text-align: right;
      font-size: 0.9em;
      color: #656d76;
      margin-bottom: 1.5em;
    }
    .chip {
      display: inline-block; padding: 1px 7px; border-radius: 999px;
      font-size: .72em; font-weight: 600; color: #1f2328;
      text-align: center; white-space: nowrap; line-height: 1.6;
    }
    .chip.math  { background: var(--subj-math); }
    .chip.comp  { background: var(--subj-comp); }
    .chip.phys  { background: var(--subj-phys); }
    .chip.chem  { background: var(--subj-chem); }
    .chip.bio   { background: var(--subj-bio); }
    .chip.astro { background: var(--subj-astro); }
    /* Project title sits below the Research header — tone it down */
    body > h1:first-of-type { font-size: 1.6em; margin-top: 0.8em; }
    .project-title {
      display: flex;
      justify-content: space-between;
      align-items: center;
      gap: 1em;
      margin: 0.8em 0;
    }
    .project-title h1 {
      font-size: 1.6em;
      margin: 0;
      border-bottom: none;
    }
    .section-heading {
      display: flex;
      justify-content: space-between;
      align-items: baseline;
      gap: 1em;
      border-bottom: 1px solid #d1d9e0;
      padding-bottom: 0.3em;
      margin-top: 1.5em;
    }
    .section-heading h2 {
      margin: 0;
      border-bottom: none;
      padding-bottom: 0;
    }
    .section-date {
      font-size: 0.9em;
      color: #656d76;
    }
    .setup-highlight tbody tr:first-child td { background: #fff44f; }
    .setup-highlight-all tbody tr td { background: #fff44f; }
    .instrument-table tbody tr td { background: #fff44f; }
    .instrument-table.no-highlight tbody tr td { background: transparent; }

    /* Updates-list (homepage match). Used here for the Technology section
       on a project page — list of toys used, in the same row format as the
       homepage's project list. */
    .updates-list {
      list-style: none;
      padding: 0;
      margin: 1em 0 0;
      border: 1px solid #d1d9e0;
      border-radius: 10px;
      overflow: hidden;
      background: #fff;
    }
    .updates-list li {
      display: flex;
      gap: 1em;
      align-items: baseline;
      padding: 0.55em 1em 0.55em 1.4em;
      border-bottom: 1px solid #eaecef;
      line-height: 1.6;
      position: relative;
      transition: background 0.15s ease;
    }
    .updates-list li:last-child { border-bottom: none; }
    .updates-list li:nth-child(even) { background: #f6f8fa; }
    .updates-list li:hover { background: #eef1f4; }
    .updates-list li::before {
      content: '';
      position: absolute;
      left: 0; top: 0; bottom: 0;
      width: 5px;
      background: var(--accent, #d1d9e0);
    }
    .updates-list li[data-subj="math"]  { --accent: var(--subj-math); }
    .updates-list li[data-subj="comp"]  { --accent: var(--subj-comp); }
    .updates-list li[data-subj="phys"]  { --accent: var(--subj-phys); }
    .updates-list li[data-subj="chem"]  { --accent: var(--subj-chem); }
    .updates-list li[data-subj="bio"]   { --accent: var(--subj-bio); }
    .updates-list li[data-subj="astro"] { --accent: var(--subj-astro); }
    .updates-list .update-date {
      flex: 0 0 9em;
      color: #656d76;
      font-size: 0.9em;
    }
    .updates-list .update-name { flex: 0 0 9em; }
    .updates-list .update-desc {
      flex: 1;
      color: #57606a;
      font-size: 0.92em;
    }
    .updates-list .update-body { flex: 1; }
    .updates-list .chip { margin-left: 0.2em; }
    @media (max-width: 600px) {
      .updates-list .update-date,
      .updates-list .update-desc { display: none; }
    }
  </style>
</head>
<body>
  <PageHeader title="Research" />

  <div class="project-title">
    <h1>
      {title}
      {mi && (
        <a class="photo-icon" href="/olympiads/photos/ctyphysics.jpeg">
          <img src="/cat.svg" alt="Mi" style="height:0.85em;vertical-align:-0.12em;" />
        </a>
      )}
    </h1>
    {sciences.length === 1 ? (
      <a class={`chip ${SLUG[sciences[0]]}`} href={`/research/#${SLUG[sciences[0]]}`}>{sciences[0]}</a>
    ) : (
      <span class="project-chips">
        {sciences.map((s, i) => (
          <>
            {i > 0 && ' '}
            <a class={`chip ${SLUG[s]}`} href={`/research/#${SLUG[s]}`}>{s}</a>
          </>
        ))}
      </span>
    )}
  </div>

  <slot />

  <hr />

  <PageFooter />

  <script src={photoPreviewJs} is:inline></script>
  <script is:inline>
    // Top photo grid: shuffle on load and expose the function for the Shuffle button.
    window.shufflePhotos = function() {
      var photos = (window._pagePhotos || []).slice();
      for (var i = photos.length - 1; i > 0; i--) {
        var j = Math.floor(Math.random() * (i + 1));
        var t = photos[i]; photos[i] = photos[j]; photos[j] = t;
      }
      for (var i = 0; i < 4; i++) {
        var el = document.getElementById('photo-' + i);
        if (el && photos[i]) el.src = photos[i];
      }
    };
    if (document.getElementById('photo-0')) window.shufflePhotos();
    // Tab containers: pick a random initial tab so viewers cycle through all of them.
    document.querySelectorAll('.tabs').forEach(function(container) {
      var radios = container.querySelectorAll('input[type="radio"]');
      if (radios.length === 0) return;
      radios[Math.floor(Math.random() * radios.length)].checked = true;
    });
  </script>
</body>
</html>
