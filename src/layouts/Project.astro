---
import './base.css';
import './tabs.css';
import faviconSvg from './favicon.svg?url';
import photoPreviewJs from './photo-preview.js?url';
import PageHeader from './PageHeader.astro';
import PageFooter from './PageFooter.astro';

interface ProjectLink {
  url: string;
  title: string;
}

interface Props {
  project: string;
  title?: string;
  htmlLang?: string;
  newer?: ProjectLink | null;
  older?: ProjectLink | null;
  photos?: string[];
}

const {
  project,
  title,
  htmlLang = 'en',
  newer = null,
  older = null,
  photos = [],
} = Astro.props;
---
<!DOCTYPE html>
<html lang={htmlLang}>
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <link rel="icon" type="image/svg+xml" href={faviconSvg} />
  <title>{project || title || 'Vivian Dai'}</title>
  <script is:inline set:html={`window._pagePhotos = ${JSON.stringify(photos)};`} />
  <style is:global>
    /* Project layout specific styles */
    .photo-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 0.5em;
      margin: 1em 0 0.5em 0;
    }
    .photo-grid img {
      width: 100%;
      height: 200px;
      object-fit: cover;
      border-radius: 6px;
    }
    .photo-grid.three-col {
      grid-template-columns: 1fr 1fr 1fr;
    }
    .shuffle-btn {
      display: block;
      margin: 0 auto 1.5em auto;
      padding: 0.4em 1.2em;
      border: 1px solid #d1d9e0;
      border-radius: 6px;
      background: #f6f8fa;
      color: #1f2328;
      font-size: 0.85em;
      cursor: pointer;
      transition: background 0.15s, border-color 0.15s;
    }
    .shuffle-btn:hover {
      background: #ddf4ff;
      border-color: #0969da;
    }
    .hero-single img {
      width: 100%;
      height: 250px;
      object-fit: cover;
      border-radius: 6px;
      margin: 1em 0 0.5em 0;
    }
    .project-meta {
      text-align: right;
      font-size: 0.9em;
      color: #656d76;
      margin-bottom: 1.5em;
    }
    .chip {
      display: inline-block; padding: 1px 7px; border-radius: 999px;
      font-size: .72em; font-weight: 600; color: #1f2328;
      text-align: center; white-space: nowrap; line-height: 1.6;
    }
    .chip.math  { background: var(--subj-math); }
    .chip.comp  { background: var(--subj-comp); }
    .chip.phys  { background: var(--subj-phys); }
    .chip.chem  { background: var(--subj-chem); }
    .chip.bio   { background: var(--subj-bio); }
    .chip.astro { background: var(--subj-astro); }
    /* Project title sits below the Research header — tone it down */
    body > h1:first-of-type { font-size: 1.6em; margin-top: 0.8em; }
    .project-title {
      display: flex;
      justify-content: space-between;
      align-items: center;
      gap: 1em;
      margin: 0.8em 0;
    }
    .project-title h1 {
      font-size: 1.6em;
      margin: 0;
      border-bottom: none;
    }
    .section-heading {
      display: flex;
      justify-content: space-between;
      align-items: baseline;
      gap: 1em;
      border-bottom: 1px solid #d1d9e0;
      padding-bottom: 0.3em;
      margin-top: 1.5em;
    }
    .section-heading h2 {
      margin: 0;
      border-bottom: none;
      padding-bottom: 0;
    }
    .section-date {
      font-size: 0.9em;
      color: #656d76;
    }
    .setup-highlight tbody tr:first-child td { background: #fff44f; }
    .setup-highlight-all tbody tr td { background: #fff44f; }
    .instrument-table tbody tr td { background: #fff44f; }
    .instrument-table.no-highlight tbody tr td { background: transparent; }
    .project-nav {
      display: flex;
      justify-content: space-between;
      gap: 1em;
      font-size: 0.9em;
      margin-top: 0.3em;
    }
    hr + .project-nav { margin-top: 0.8em; }
    .project-nav a { color: #0969da; text-decoration: none; }
    .project-nav a:hover { text-decoration: underline; }
    .project-nav .spacer { flex: 1; }
    body:has(.project-nav-top) .page-header { border-bottom: none; padding-bottom: 0; }
    .project-nav.project-nav-top {
      margin-top: 0.3em;
      padding-bottom: 0.3em;
      border-bottom: 1px solid #d1d9e0;
      margin-bottom: 0.5em;
    }
    .project-nav + hr { margin-top: 0.5em; }
  </style>
</head>
<body>
  <PageHeader title="Research" />

  {newer && older && (
    <nav class="project-nav project-nav-top">
      <a href={newer.url}>← {newer.title}</a>
      <a href={older.url}>{older.title} →</a>
    </nav>
  )}

  <slot />

  <hr />

  {newer && older && (
    <nav class="project-nav">
      <a href={newer.url}>← {newer.title}</a>
      <a href={older.url}>{older.title} →</a>
    </nav>
  )}

  <PageFooter />

  <script>
    // Move project-nav-top below page-header on hydration so the back/forward
    // strip sits flush under the header instead of above the page title.
    const topNav = document.querySelector('.project-nav-top');
    const header = document.querySelector('.page-header');
    if (header && topNav) header.insertAdjacentElement('afterend', topNav);
  </script>
  <script src={photoPreviewJs} is:inline></script>
  <script is:inline>
    // Top photo grid: shuffle on load and expose the function for the Shuffle button.
    window.shufflePhotos = function() {
      var photos = (window._pagePhotos || []).slice();
      for (var i = photos.length - 1; i > 0; i--) {
        var j = Math.floor(Math.random() * (i + 1));
        var t = photos[i]; photos[i] = photos[j]; photos[j] = t;
      }
      for (var i = 0; i < 4; i++) {
        var el = document.getElementById('photo-' + i);
        if (el && photos[i]) el.src = photos[i];
      }
    };
    if (document.getElementById('photo-0')) window.shufflePhotos();
    // Tab containers: pick a random initial tab so viewers cycle through all of them.
    document.querySelectorAll('.tabs').forEach(function(container) {
      var radios = container.querySelectorAll('input[type="radio"]');
      if (radios.length === 0) return;
      radios[Math.floor(Math.random() * radios.length)].checked = true;
    });
  </script>
</body>
</html>
