---
type Section = 'home' | 'curriculum' | 'olympiads' | 'research';

interface Props {
  // Marks one nav link as active. Omit on sub-pages (like a project page)
  // where the section nav link should still navigate, not scroll-to-top.
  active?: Section;
  // Explicit H2 text. Defaults to the active section's label, or "Science".
  title?: string;
  // Override per-section href. Sub-pages use this to land back on the
  // index with a hash — e.g. a tech page sends Research to
  // /research/#math so the matching column is highlighted on arrival.
  curriculumHref?: string;
  olympiadsHref?: string;
  researchHref?: string;
}

const { active, title, curriculumHref, olympiadsHref, researchHref } = Astro.props;

// On the home page itself, the H2 already says "Science" — skip the duplicate
// nav entry. On every other page, the "Science" link is the way back home.
const allLinks: Array<{ id: Section; href: string; label: string }> = [
  { id: 'home',       href: '/',                              label: 'Science' },
  { id: 'curriculum', href: curriculumHref ?? '/curriculum/', label: 'Curriculum' },
  { id: 'olympiads',  href: olympiadsHref  ?? '/olympiads/',  label: 'Olympiads' },
  { id: 'research',   href: researchHref   ?? '/research/',   label: 'Research' },
];
// Drop the self-link on every section's index page — it just re-renders
// the page you're already on and crowds the mobile header. Tech and
// project sub-pages don't pass `active`, so the Research link still
// shows up there as a way back to /research/.
const links = allLinks.filter((l) => {
  if (l.id === 'home' && active === 'home') return false;
  if (l.id === 'curriculum' && active === 'curriculum') return false;
  if (l.id === 'olympiads' && active === 'olympiads') return false;
  if (l.id === 'research' && active === 'research') return false;
  return true;
});

const titles: Record<Section, string> = {
  home: 'Science',
  curriculum: 'Curriculum',
  olympiads: 'Olympiads',
  research: 'Research',
};
const heading = title ?? (active ? titles[active] : 'Science');
---
<div class="page-header">
  <h2>{heading}</h2>
  <div class="header-nav">
    {links.map((l) => (
      <a class={l.id === active ? 'active' : ''} href={l.href} data-nav={l.id}>{l.label}</a>
    ))}
  </div>
</div>
