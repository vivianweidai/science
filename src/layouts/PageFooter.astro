---
type Section = 'home' | 'curriculum' | 'olympiads' | 'research';

interface Props {
  // Marks one nav link as active. Omit on sub-pages (like a project page)
  // where the section nav link should still navigate, not scroll-to-top.
  active?: Section;
  // Override per-section href. Same pattern as PageHeader — toy pages send
  // Research to /research/#<science_slug> so the column lands highlighted.
  curriculumHref?: string;
  olympiadsHref?: string;
  researchHref?: string;
}

const { active, curriculumHref, olympiadsHref, researchHref } = Astro.props;

const links: Array<{ id: Section; href: string; label: string }> = [
  { id: 'curriculum', href: curriculumHref ?? '/curriculum/', label: 'Curriculum' },
  { id: 'olympiads',  href: olympiadsHref  ?? '/olympiads/',  label: 'Olympiads' },
  { id: 'research',   href: researchHref   ?? '/research/',   label: 'Research' },
];
---
<div class="footer">
  <slot name="lead">
    <a class="footer-github" href="/">Science</a>
  </slot>
  <div class="footer-nav">
    {links.map((l) => (
      <a class={l.id === active ? 'active' : ''} href={l.href}>{l.label}</a>
    ))}
  </div>
  <slot name="trail" />
</div>
