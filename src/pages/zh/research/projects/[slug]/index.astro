---
import { getCollection, render } from 'astro:content';
import { readdirSync, statSync, existsSync } from 'node:fs';
import { join, relative } from 'node:path';
import ProjectLayout from '../../../../../layouts/Project.astro';

export async function getStaticPaths() {
  const projects = await getCollection('zhProjects');
  const sorted = [...projects].sort((a, b) => a.id.localeCompare(b.id));

  return sorted.map((entry, idx) => {
    const folder = entry.id;

    // Photos live with the English project under public/content/; same auto-discovery as English route.
    const photosRoot = join(process.cwd(), 'public', 'content', 'research', 'projects', folder, 'photos');
    const photos: string[] = [];
    if (existsSync(photosRoot)) {
      const walk = (dir: string) => {
        for (const name of readdirSync(dir)) {
          const full = join(dir, name);
          const st = statSync(full);
          if (st.isDirectory()) {
            if (relative(photosRoot, full) === 'data') continue;
            walk(full);
          } else if (/\.(jpg|jpeg|png)$/i.test(name)) {
            photos.push(`/content/research/projects/${folder}/photos/` + relative(photosRoot, full));
          }
        }
      };
      walk(photosRoot);
    }

    const last = sorted.length - 1;
    const newerIdx = idx === last ? 0 : idx + 1;
    const olderIdx = idx === 0 ? last : idx - 1;
    const newer = sorted[newerIdx];
    const older = sorted[olderIdx];
    const linkFor = (e: typeof entry) => ({
      url: `/zh/research/projects/${encodeURI(e.id)}/`,
      title: e.data.project || e.data.title || e.id,
    });

    return {
      params: { slug: folder },
      props: { entry, photos, newer: linkFor(newer), older: linkFor(older) },
    };
  });
}

const { entry, photos, newer, older } = Astro.props;
const { Content } = await render(entry);
---
<ProjectLayout
  project={entry.data.project}
  title={entry.data.title}
  htmlLang="zh"
  photos={photos}
  newer={newer}
  older={older}
>
  <Content />
</ProjectLayout>
