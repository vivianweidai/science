---
import DefaultLayout from '../../layouts/Default.astro';
import '../../layouts/curriculum.css';
import curriculumJs from '../../layouts/curriculum.js?url';
---
<DefaultLayout title="Curriculum">
  <div class="page-header"><h2>Curriculum</h2><div class="header-nav"><a class="active" href="/curriculum/">Curriculum</a><a href="/olympiads/">Olympiads</a><a href="/research/">Research</a></div></div>

  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/katex@0.16.9/dist/katex.min.css" />

  <div id="curriculum-widget"></div>

  <script src="https://cdn.jsdelivr.net/npm/marked@12/marked.min.js" is:inline></script>
  <script defer src="https://cdn.jsdelivr.net/npm/katex@0.16.9/dist/katex.min.js" is:inline></script>
  <script defer src="https://cdn.jsdelivr.net/npm/katex@0.16.9/dist/contrib/auto-render.min.js" is:inline></script>
  <script src={curriculumJs} is:inline></script>

  <hr />

  <div class="footer"><a class="footer-github" href="/">Science</a><div class="footer-nav"><a class="active" href="/curriculum/">Curriculum</a><a href="/olympiads/">Olympiads</a><a href="/research/">Research</a></div></div>
</DefaultLayout>
