---
import DefaultLayout from '../layouts/Default.astro';
import PageHeader from '../layouts/PageHeader.astro';
import PageFooter from '../layouts/PageFooter.astro';
import scienceJpeg from '../layouts/science.jpeg?url';
import curriculumData from '../../public/curriculum/curriculum.json';
import techData from '../../public/research/tech.json';

// Top → bottom matches the science pyramid: astronomy at the apex,
// mathematics as the foundation. Each row builds on the ones below.
const SUBJECTS = ['astronomy', 'biology', 'chemistry', 'physics', 'computing', 'mathematics'];
const SUBJ_ANCHOR = {
  mathematics: 'math', computing: 'comp', physics: 'phys',
  chemistry: 'chem', biology: 'bio', astronomy: 'astro',
};
// Latest olympiad result per subject, picked from public/olympiads/olympiads.yml.
// kind mirrors the olympiads page: 'invited' (⭐ sparkle) | 'competitive' (🎯 wiggle) | ''.
const OLYMPIAD_LATEST = {
  mathematics: { name: 'American Mathematics Competition 12',                                 icon: '🎯',  kind: 'competitive', date: 'November 2025' },
  computing:   { name: 'North American Computational Linguistics Open Exam',                  icon: '',    kind: '',            date: 'January 2026'  },
  physics:     { name: 'Junior Science Olympiad of Canada Exam',                              icon: '🎯',  kind: 'competitive', date: 'March 2026'    },
  chemistry:   { name: 'United States National Chemistry Olympiad Local Exam',                icon: '🎯',  kind: 'competitive', date: 'March 2026'    },
  biology:     { name: 'USA Biology Olympiad Open Exam',                                      icon: '🎯',  kind: 'competitive', date: 'February 2026' },
  astronomy:   { name: 'Canadian Astronomy and Astrophysics Olympiad Senior National Camp',   icon: '⭐', kind: 'invited',     date: 'May 2026'      },
};
const RESEARCH_LATEST = {
  mathematics: { name: 'Red or Green, What Colored Cat Food does Mi Prefer?', url: '/research/projects/20250225%20Catfood/',                            mi: true },
  computing:   { name: 'Red or Green, What Colored Cat Food does Mi Prefer?', url: '/research/projects/20250225%20Catfood/',                            mi: true },
  physics:     { name: 'Four-Point Probe Sheet Resistance Measurements',      url: '/research/projects/20260404%20Four%20Point%20Probe/'                          },
  chemistry:   { name: 'IR Spectroscopy of Everyday Materials',               url: '/research/projects/20260419%20IR%20Spectroscopy/'                             },
  biology:     { name: 'Meow to Mars — Will Space Help or Hurt Mi’s Heart?',  url: '/research/projects/20260401%20Genes%20in%20Space/',                 mi: true },
  astronomy:   { name: 'Wolfram — Dry Run',                                   url: 'https://www.wolframcloud.com/obj/jamesdai/Published/exoplanets.nb'           },
};
// Two research topics per science, sourced from tech.yml. Drives the
// right-hand chips in the Research tab — both link to the science's
// filtered view at /research/#<anchor>.
const RESEARCH_TOPICS = {};
for (const t of techData.topics) {
  const slug = t.science.toLowerCase();
  if (!RESEARCH_TOPICS[slug]) RESEARCH_TOPICS[slug] = [];
  RESEARCH_TOPICS[slug].push(t.topic);
}
const TABS = [
  { key: 'curriculum', label: 'Curriculum' },
  { key: 'olympiads',  label: 'Olympiads'  },
  { key: 'research',   label: 'Research'   },
];
---
<DefaultLayout title="Science">
  <PageHeader active="home" />

  <div class="hero-pool fade-in">
    <img class="hero-img" src={scienceJpeg} alt="Science" width="100%" />
    <canvas class="hero-canvas"></canvas>
  </div>

  <div class="curr-rows" data-active="curriculum">
    <div class="curr-rows-tabs">
      <div class="curr-rows-tabs-inner">
        {TABS.map(t => (
          <button class="curr-rows-tab" data-target={t.key} type="button">
            <span class="curr-rows-tab-text">{t.label}</span>
            <span class="curr-rows-progress"></span>
          </button>
        ))}
      </div>
    </div>
    <div class="curr-rows-body">
    {SUBJECTS.map((subjSlug, i) => {
      const subj = curriculumData[subjSlug];
      const olyKind = OLYMPIAD_LATEST[subjSlug].kind;
      return (
        <div class="curr-rows-row fade-in" data-olympiad-kind={olyKind} style={`animation-delay: ${0.1 + i * 0.08}s`}>
          <a class="curr-rows-subj" data-subj={subjSlug} data-tab="curriculum" href={`/curriculum/#${subjSlug}`}>{subj.name}</a>
          <a class="curr-rows-subj" data-subj={subjSlug} data-tab="olympiads"  href={`/olympiads/#${SUBJ_ANCHOR[subjSlug]}`}>{subj.name}</a>
          <a class="curr-rows-subj" data-subj={subjSlug} data-tab="research"   href={`/research/#${SUBJ_ANCHOR[subjSlug]}`}>{subj.name}</a>

          <div class="curr-rows-secs" data-tab="curriculum">
            {subj.sections.map((sec, j) => (
              <>
                {j > 0 && <span class="sep">·</span>}
                <a href={`/curriculum/#${subjSlug}/${sec.slug}`}>{sec.name}</a>
              </>
            ))}
          </div>
          <div class="curr-rows-secs" data-tab="olympiads">
            <a href={`/olympiads/#${SUBJ_ANCHOR[subjSlug]}`}>{OLYMPIAD_LATEST[subjSlug].name}</a>
            {OLYMPIAD_LATEST[subjSlug].icon && (
              <span class={`status-emoji status-emoji-${OLYMPIAD_LATEST[subjSlug].kind}`}>
                <span class="glyph">{OLYMPIAD_LATEST[subjSlug].icon}</span>
              </span>
            )}
          </div>
          <div class="curr-rows-secs" data-tab="research">
            <a href={RESEARCH_LATEST[subjSlug].url}>{RESEARCH_LATEST[subjSlug].name}</a>
            {RESEARCH_LATEST[subjSlug].mi && (
              <a class="photo-icon mi-icon" href="/mi.jpeg">
                <img src="/mi.svg" alt="Mi" />
              </a>
            )}
          </div>

          <a class="curr-rows-pdf" data-tab="curriculum" href={`/curriculum/notes/${subjSlug}.pdf`}>pdf</a>
          <span class="curr-rows-date" data-tab="olympiads">{OLYMPIAD_LATEST[subjSlug].date}</span>
          {(olyKind === 'competitive' || olyKind === 'invited') && (
            <span class="olympiad-badge" data-tab="olympiads">{olyKind.toUpperCase()}</span>
          )}
          <span class="curr-rows-topics" data-tab="research">
            {RESEARCH_TOPICS[subjSlug].map((topic, k) => (
              <>
                {k > 0 && <span class="sep">·</span>}
                <a href={`/research/#${SUBJ_ANCHOR[subjSlug]}/${topic.toLowerCase().replace(/\s+/g, '-')}`}>{topic}</a>
              </>
            ))}
          </span>
        </div>
      );
    })}
    </div>
  </div>

  <style>
    .hero-pool {
      position: relative;
      display: block;
      margin-top: 1em;
      border-radius: 8px;
      overflow: hidden;
      transition: transform 0.5s cubic-bezier(.2,.8,.2,1), box-shadow 0.5s ease, filter 0.5s ease;
    }
    .hero-img {
      display: block;
      width: 100%;
    }
    .hero-canvas {
      position: absolute;
      inset: 0;
      pointer-events: none;
    }
    .hero-pool:hover {
      transform: scale(1.01);
      filter: brightness(1.02);
      box-shadow: 0 5px 14px rgba(0,0,0,.06);
    }
    .curr-rows {
      margin: 2em 0;
      transition: transform 0.2s ease-out, filter 0.18s ease;
    }
    @media (hover: hover) {
      .curr-rows:hover {
        transform: translate(-2px, -2px);
        filter: drop-shadow(0 6px 12px rgba(0,0,0,.08));
      }
    }
    .curr-rows-body {
      border: 1px solid #d1d9e0;
      border-radius: 8px;
      overflow: hidden;
    }
    .curr-rows-tabs {
      display: flex;
      justify-content: center;
    }
    .curr-rows-tabs-inner {
      display: flex;
    }
    .curr-rows-tab {
      display: block;
      position: relative;
      overflow: hidden;
      padding: 0.6em 1.2em;
      background: transparent;
      border: none;
      font-family: inherit;
      font-weight: 600;
      font-size: 0.9em;
      color: #656d76;
      text-align: center;
      cursor: pointer;
      transition: color 0.15s, background 0.15s;
    }
    .curr-rows-tab:hover { color: #1f2328; }
    .curr-rows[data-active="curriculum"] .curr-rows-tab[data-target="curriculum"],
    .curr-rows[data-active="olympiads"]  .curr-rows-tab[data-target="olympiads"],
    .curr-rows[data-active="research"]   .curr-rows-tab[data-target="research"] {
      color: #1f2328;
      background: #e8e8e8;
    }

    .curr-rows-tab-text {
      position: relative;
      z-index: 1;
    }
    /* Timer wave — only rendered on the active tab. Hidden on non-active
       tabs so they stay crisp on hover. */
    .curr-rows-progress {
      position: absolute;
      top: 0;
      bottom: 0;
      left: -60%;
      width: 60%;
      background: linear-gradient(to right,
        transparent 0%,
        rgba(31,35,40,0.008) 50%,
        rgba(31,35,40,0.025) 90%,
        rgba(31,35,40,0.07) 100%);
      pointer-events: none;
      display: none;
    }
    .curr-rows[data-active="curriculum"] .curr-rows-tab[data-target="curriculum"] .curr-rows-progress,
    .curr-rows[data-active="olympiads"]  .curr-rows-tab[data-target="olympiads"]  .curr-rows-progress,
    .curr-rows[data-active="research"]   .curr-rows-tab[data-target="research"]   .curr-rows-progress {
      display: block;
    }

    /* Tab visibility: hide rows-content not matching active tab */
    .curr-rows[data-active="curriculum"] .curr-rows-row [data-tab]:not([data-tab="curriculum"]),
    .curr-rows[data-active="olympiads"]  .curr-rows-row [data-tab]:not([data-tab="olympiads"]),
    .curr-rows[data-active="research"]   .curr-rows-row [data-tab]:not([data-tab="research"]) {
      display: none;
    }

    .curr-rows-row {
      display: flex;
      align-items: center;
      border-bottom: 1px solid #eaecef;
      font-size: 0.9em;
      min-height: 3.3em;
      transition: background 0.15s ease;
      position: relative;
    }

    /* Yellow ripple sweep + flashing badge on hover for competitive/invited
       olympiad rows. Mirrors the .hl-hover treatment on /olympiads/. Only
       active when the Olympiads tab is showing. */
    .curr-rows[data-active="olympiads"] .curr-rows-row[data-olympiad-kind="competitive"],
    .curr-rows[data-active="olympiads"] .curr-rows-row[data-olympiad-kind="invited"] {
      isolation: isolate;
    }
    .curr-rows[data-active="olympiads"] .curr-rows-row[data-olympiad-kind="competitive"]::before,
    .curr-rows[data-active="olympiads"] .curr-rows-row[data-olympiad-kind="invited"]::before {
      content: '';
      position: absolute;
      inset: 0;
      background-image: linear-gradient(100deg, transparent 0%, #fff44f 50%, transparent 100%);
      background-size: 50% 100%;
      background-repeat: no-repeat;
      background-position: -100% 0;
      z-index: -1;
      pointer-events: none;
    }
    .curr-rows[data-active="olympiads"] .curr-rows-row[data-olympiad-kind="competitive"]:hover::before,
    .curr-rows[data-active="olympiads"] .curr-rows-row[data-olympiad-kind="invited"]:hover::before {
      animation: oly-row-ripple 1.0s ease-out;
    }
    @keyframes oly-row-ripple {
      from { background-position: -60% 0; }
      to   { background-position: 200% 0; }
    }
    .olympiad-badge {
      position: absolute;
      right: 0.6em;
      top: 50%;
      font-size: 0.6em;
      font-weight: 700;
      letter-spacing: 0.12em;
      background: #1f2328;
      color: #fff44f;
      padding: 0.25em 0.55em;
      border-radius: 3px;
      opacity: 0;
      pointer-events: none;
      transform: translate(-0.5em, -50%);
    }
    .curr-rows[data-active="olympiads"] .curr-rows-row:hover .olympiad-badge {
      animation: oly-badge-flash 1.0s ease-out;
    }
    @keyframes oly-badge-flash {
      0%   { opacity: 0; transform: translate(-0.5em, -50%); }
      20%  { opacity: 1; transform: translate(0, -50%); }
      70%  { opacity: 1; transform: translate(0, -50%); }
      100% { opacity: 0; transform: translate(0.5em, -50%); }
    }
    /* Fade the date out while the badge is on top of it (mirrors the
       badge-flash timing exactly). Only fires for rows that have a badge. */
    .curr-rows[data-active="olympiads"] .curr-rows-row[data-olympiad-kind="competitive"]:hover .curr-rows-date,
    .curr-rows[data-active="olympiads"] .curr-rows-row[data-olympiad-kind="invited"]:hover .curr-rows-date {
      animation: oly-date-mute 1.0s ease-out;
    }
    @keyframes oly-date-mute {
      0%   { opacity: 1; }
      20%  { opacity: 0; }
      70%  { opacity: 0; }
      100% { opacity: 1; }
    }
    .curr-rows-row:nth-child(odd) { background: #f6f8fa; }
    .curr-rows-row:hover { background: #eef1f4; }
    .curr-rows-row:last-child { border-bottom: none; }
    .curr-rows-subj {
      flex: 0 0 130px;
      align-self: stretch;
      display: flex;
      align-items: center;
      padding: 0.55em 0.9em;
      font-weight: 600;
      color: #1f2328;
      text-decoration: none;
      transition: filter 0.18s ease;
    }
    .curr-rows-subj:hover {
      filter: brightness(0.94) saturate(1.2);
      text-decoration: underline;
    }
    .curr-rows-row:hover .curr-rows-subj {
      filter: brightness(0.94) saturate(1.2);
    }
    .curr-rows-subj[data-subj="mathematics"] { background: var(--subj-math); }
    .curr-rows-subj[data-subj="computing"]   { background: var(--subj-comp); }
    .curr-rows-subj[data-subj="physics"]     { background: var(--subj-phys); }
    .curr-rows-subj[data-subj="chemistry"]   { background: var(--subj-chem); }
    .curr-rows-subj[data-subj="biology"]     { background: var(--subj-bio); }
    .curr-rows-subj[data-subj="astronomy"]   { background: var(--subj-astro); }
    .curr-rows-secs {
      flex: 1;
      padding: 0.55em 1em;
    }
    .curr-rows-secs a {
      color: #1f2328;
      text-decoration: none;
      padding: 0 0.18em;
    }
    .curr-rows-secs a:hover { color: #0969da; text-decoration: underline; }
    .curr-rows-secs .sep { color: #b1b7be; padding: 0 0.15em; }
    .curr-rows-secs .mi-icon {
      margin-left: 0.35em;
      display: inline-flex;
      align-items: center;
      vertical-align: middle;
      cursor: default;
    }
    .curr-rows-secs .mi-icon img { height: 0.95em; }
    .curr-rows-secs .mi-icon:hover { text-decoration: none; }
    .curr-rows-pdf {
      flex: 0 0 auto;
      margin-right: 0.7em;
      padding: 0.18em 0.65em;
      border: 1px solid #d1d9e0;
      border-radius: 999px;
      background: #f6f8fa;
      color: #57606a;
      font-size: 0.82em;
      letter-spacing: 0.02em;
      text-decoration: none;
      white-space: nowrap;
    }
    .curr-rows-pdf:hover {
      background: #eaeef2;
      color: #1f2328;
      text-decoration: none;
    }

    .curr-rows-date {
      flex: 0 0 auto;
      margin-right: 0.9em;
      color: #57606a;
      font-size: 0.85em;
      white-space: nowrap;
    }
    .curr-rows-topics {
      flex: 0 0 auto;
      margin-right: 0.9em;
      font-size: 0.85em;
      white-space: nowrap;
    }
    .curr-rows-topics a {
      color: #57606a;
      text-decoration: none;
      padding: 0 0.18em;
    }
    .curr-rows-topics a:hover { color: #0969da; text-decoration: underline; }
    .curr-rows-topics .sep { color: #b1b7be; padding: 0 0.15em; }

    /* Olympiad row content uses flex so the achievement icon sits on the
       same vertical centerline as the text instead of dropping below the
       baseline (emoji glyphs have their own metrics that don't center
       naturally). */
    .curr-rows-secs[data-tab="olympiads"] {
      display: flex;
      align-items: center;
    }

    /* Olympiad achievement icons — same wiggle/shimmer treatment as
       /olympiads/ timeline. The icon sits OUTSIDE the link so the
       underline doesn't extend over the glyph. */
    .status-emoji {
      font-size: 1em;
      margin-left: 0.4em;
      display: inline-flex;
      align-items: center;
      cursor: default;
      transform: translateY(-0.08em); /* nudge to optical center; emojis sit below the text baseline by default */
    }
    .status-emoji .glyph {
      display: inline-flex;
      align-items: center;
      position: relative;
    }
    .status-emoji-competitive { transform-origin: center 80%; }
    .status-emoji-competitive:hover,
    .curr-rows-row:hover .status-emoji-competitive {
      animation: status-wiggle 0.55s ease;
    }
    @keyframes status-wiggle {
      0%   { transform: rotate(0); }
      20%  { transform: rotate(-15deg); }
      40%  { transform: rotate(12deg); }
      60%  { transform: rotate(-8deg); }
      80%  { transform: rotate(5deg); }
      100% { transform: rotate(0); }
    }
    .status-emoji-invited .glyph { transform-origin: center; display: inline-block; }
    .status-emoji-invited:hover .glyph,
    .curr-rows-row:hover .status-emoji-invited .glyph {
      animation: status-sparkle 0.75s ease;
    }
    @keyframes status-sparkle {
      0%   { transform: scale(1) rotate(0); filter: none; }
      25%  { transform: scale(1.4) rotate(-15deg); filter: drop-shadow(0 0 6px rgba(255,200,40,0.9)); }
      55%  { transform: scale(0.92) rotate(10deg); filter: drop-shadow(0 0 2px rgba(255,200,40,0.4)); }
      80%  { transform: scale(1.12) rotate(-4deg); filter: drop-shadow(0 0 4px rgba(255,200,40,0.6)); }
      100% { transform: scale(1) rotate(0); filter: none; }
    }
    @media (max-width: 600px) {
      .curr-rows-row {
        flex-direction: column;
        align-items: stretch;
        min-height: 0;
      }
      .curr-rows-subj { flex: none; text-align: center; }
      .curr-rows-pdf,
      .curr-rows-date,
      .curr-rows-topics,
      .curr-rows-secs[data-tab="curriculum"] { display: none; }
      .curr-rows-secs { padding: 0.65em 1em; }
    }
    .footer-store-links { display: flex; gap: 0.5em; }
  </style>

  <script is:inline>
    // Hero pool: cursor-trail particles + click ripples in the six subject colors.
    (function () {
      var pool = document.querySelector('.hero-pool');
      if (!pool) return;
      var canvas = pool.querySelector('.hero-canvas');
      var ctx = canvas.getContext('2d');
      var COLORS = ['#c5d9f7', '#d9ccee', '#f9c4a8', '#d4e8a0', '#a8ddd4', '#f4c2cb'];
      var particles = [];
      var ripples = [];
      var dpr = Math.max(1, window.devicePixelRatio || 1);

      function resize() {
        var rect = pool.getBoundingClientRect();
        if (rect.width === 0 || rect.height === 0) return; // hero img not loaded yet
        canvas.width = Math.round(rect.width * dpr);
        canvas.height = Math.round(rect.height * dpr);
        canvas.style.width = rect.width + 'px';
        canvas.style.height = rect.height + 'px';
        ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
      }
      resize();
      window.addEventListener('resize', resize);
      // Image may load after the script runs; resize once it has real dimensions.
      var heroImg = pool.querySelector('img');
      if (heroImg && !heroImg.complete) heroImg.addEventListener('load', resize);
      if (typeof ResizeObserver !== 'undefined') new ResizeObserver(resize).observe(pool);

      var lastBubble = 0;
      var colorIdx = 0;
      pool.addEventListener('mousemove', function (e) {
        var rect = pool.getBoundingClientRect();
        var x = e.clientX - rect.left;
        var y = e.clientY - rect.top;
        var now = performance.now();
        // Bubble trail — long-lived particles form a visible tail behind the cursor.
        if (now - lastBubble >= 14 + Math.random() * 10) {
          lastBubble = now;
          colorIdx = (colorIdx + 1) % COLORS.length;
          particles.push({
            x: x + (Math.random() - 0.5) * 4,
            y: y + (Math.random() - 0.5) * 4,
            vx: (Math.random() - 0.5) * 0.3,
            vy: (Math.random() - 0.5) * 0.3 - 0.05,
            r: 9 + Math.random() * 9,
            color: COLORS[colorIdx],
            life: 1,
            decay: 0.0065 + Math.random() * 0.0075, // ~2-3s lifespan → real tail
            glow: 16 + Math.random() * 12
          });
        }
      });

      pool.addEventListener('click', function (e) {
        var rect = pool.getBoundingClientRect();
        var x = e.clientX - rect.left;
        var y = e.clientY - rect.top;
        var color = COLORS[Math.floor(Math.random() * COLORS.length)];
        var minSide = Math.min(rect.width, rect.height);
        // Click ripple — random ellipse, smaller max diameter than before.
        // Stroke is thick at spawn and thins as the ellipse expands (renderer
        // ties lineWidth to remaining progress (1 - t)^2).
        ripples.push({
          x: x, y: y,
          t: 0,
          growT: 0.012 + Math.random() * 0.008,
          rxMax: minSide * (0.14 + Math.random() * 0.10),
          ryMax: minSide * (0.12 + Math.random() * 0.10),
          rotation: Math.random() * Math.PI * 2,
          color: color,
          lw: 20 + Math.random() * 10
        });
        // Smaller echo ring for the water-drop feel.
        setTimeout(function () {
          ripples.push({
            x: x, y: y,
            t: 0,
            growT: 0.013 + Math.random() * 0.007,
            rxMax: minSide * (0.08 + Math.random() * 0.08),
            ryMax: minSide * (0.07 + Math.random() * 0.08),
            rotation: Math.random() * Math.PI * 2,
            color: color,
            lw: 13 + Math.random() * 6
          });
        }, 110 + Math.random() * 110);
      });

      function tick() {
        var rect = pool.getBoundingClientRect();
        ctx.clearRect(0, 0, rect.width, rect.height);

        for (var i = particles.length - 1; i >= 0; i--) {
          var p = particles[i];
          p.x += p.vx;
          p.y += p.vy;
          p.life -= p.decay;
          if (p.life <= 0) { particles.splice(i, 1); continue; }
          var ls = p.life * p.life; // quadratic falloff → strong fade with distance
          ctx.globalAlpha = ls * 0.95;
          ctx.shadowColor = p.color;
          ctx.shadowBlur = p.glow * p.life;
          ctx.fillStyle = p.color;
          ctx.beginPath();
          ctx.arc(p.x, p.y, p.r * Math.sqrt(p.life), 0, Math.PI * 2);
          ctx.fill();
        }
        ctx.shadowBlur = 0;

        for (var j = ripples.length - 1; j >= 0; j--) {
          var rp = ripples[j];
          rp.t += rp.growT;
          if (rp.t >= 1) { ripples.splice(j, 1); continue; }
          var remaining = 1 - rp.t;
          ctx.globalAlpha = remaining * 0.9;
          ctx.strokeStyle = rp.color;
          var tt = rp.t * rp.t;
          ctx.lineWidth = rp.lw * (1 - tt * tt * tt); // (1 - t^6) — holds full thickness almost to the end, then drops sharply
          ctx.beginPath();
          ctx.ellipse(rp.x, rp.y, rp.rxMax * rp.t, rp.ryMax * rp.t, rp.rotation, 0, Math.PI * 2);
          ctx.stroke();
        }
        ctx.globalAlpha = 1;

        requestAnimationFrame(tick);
      }
      requestAnimationFrame(tick);
    })();

    (function () {
      var container = document.querySelector('.curr-rows[data-active]');
      if (!container) return;
      var fills = container.querySelectorAll('.curr-rows-tab .curr-rows-progress');
      var tabs = ['curriculum', 'olympiads', 'research'];
      var tabMs = 5000;
      var cycleMs = tabs.length * tabMs;
      // Random starting tab on each page load; the timer ticks on from
      // there (offset cycleStart so elapsed lands inside that tab).
      var startIdx = Math.floor(Math.random() * tabs.length);
      container.dataset.active = tabs[startIdx];
      var cycleStart = performance.now() - startIdx * tabMs;
      var rafId = 0;
      var stopped = false;

      function clearFills() {
        for (var i = 0; i < fills.length; i++) fills[i].style.left = '-60%';
      }

      function tick(now) {
        if (stopped) return;
        var elapsed = (now - cycleStart) % cycleMs;
        var idx = Math.floor(elapsed / tabMs);
        var withinTab = (elapsed % tabMs) / tabMs;
        clearFills();
        if (fills[idx]) fills[idx].style.left = (withinTab * 100 - 60) + '%';
        var target = tabs[idx];
        if (container.dataset.active !== target) {
          container.dataset.active = target;
        }
        rafId = requestAnimationFrame(tick);
      }
      rafId = requestAnimationFrame(tick);

      function stop() {
        if (stopped) return;
        stopped = true;
        cancelAnimationFrame(rafId);
        clearFills();
      }
      container.addEventListener('mouseenter', stop);

      container.querySelectorAll('.curr-rows-tab').forEach(function (btn) {
        btn.addEventListener('click', function () {
          stop();
          container.dataset.active = btn.dataset.target;
        });
      });
    })();
  </script>

