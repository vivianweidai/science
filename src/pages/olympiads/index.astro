---
import DefaultLayout from '../../layouts/Default.astro';
import PageHeader from '../../layouts/PageHeader.astro';
import PageFooter from '../../layouts/PageFooter.astro';
---
<DefaultLayout title="Olympiads">
  <PageHeader active="olympiads" />

  <div class="tabs subject-tabs">
    <input type="radio" name="view" id="view-all" />
    <input type="radio" name="view" id="view-math" />
    <input type="radio" name="view" id="view-comp" />
    <input type="radio" name="view" id="view-phys" />
    <input type="radio" name="view" id="view-chem" />
    <input type="radio" name="view" id="view-bio" />
    <input type="radio" name="view" id="view-astro" />
    <script is:inline>
      (function(){
        var tabs = ['view-math','view-comp','view-phys','view-chem','view-bio','view-astro'];
        // Hash takes precedence so a chip click on another page can deep-link
        // straight to the right tab. Fall through to the saved tab, then
        // a random pick.
        var hash = (location.hash || '').replace(/^#/, '');
        var saved = sessionStorage.getItem('subj-tab');
        var pick;
        if (hash && document.getElementById('view-' + hash)) pick = 'view-' + hash;
        else if (saved && document.getElementById('view-' + saved)) pick = 'view-' + saved;
        else pick = tabs[Math.floor(Math.random() * tabs.length)];
        document.getElementById(pick).checked = true;
        sessionStorage.setItem('subj-tab', pick.replace('view-', ''));
        window.addEventListener('hashchange', function(){
          var h = (location.hash || '').replace(/^#/, '');
          var el = document.getElementById('view-' + h);
          if (!el) return;
          el.checked = true;
          sessionStorage.setItem('subj-tab', h);
          el.dispatchEvent(new Event('change', { bubbles: true }));
        });
      })();
    </script>

    <div class="tab-labels">
      <label for="view-all"><span class="label-full">All</span><span class="label-abbr">All</span></label>
      <label for="view-math"><span class="label-full">Mathematics</span><span class="label-abbr">Math</span></label>
      <label for="view-comp"><span class="label-full">Computing</span><span class="label-abbr">Comp</span></label>
      <label for="view-phys"><span class="label-full">Physics</span><span class="label-abbr">Phys</span></label>
      <label for="view-chem"><span class="label-full">Chemistry</span><span class="label-abbr">Chem</span></label>
      <label for="view-bio"><span class="label-full">Biology</span><span class="label-abbr">Bio</span></label>
      <label for="view-astro"><span class="label-full">Astronomy</span><span class="label-abbr">Astro</span></label>
    </div>
  </div>

  <div class="timeline-card-wrap">
    <div id="timeline"></div>
  </div>

  <style is:global>
    /* Tab-content card wrapper. Mirrors the research-page topic card and
       the toy/curriculum leaf-card treatment: 1 px gray border + 4 px
       science-colored left accent (changes with the active tab) + a
       soft science-tinted wash. Default stays gray for the All tab. */
    /* Hover hit-region wrapper. 2 px of bottom/right padding catches the
       cursor when #timeline lifts up-and-left on hover so the :hover
       state doesn't drop and re-fire (same trick as .toys-card-wrap). */
    .timeline-card-wrap {
      margin: 1em 0;
      padding: 0 2px 2px 0;
    }
    #timeline {
      border: 1px solid #d1d9e0;
      border-left: 4px solid #d1d9e0;
      border-radius: 8px;
      padding: 0.6em 1.2em 1.2em;
      background: color-mix(in srgb, var(--card-tint, #d1d9e0) 18%, white);
      transition: transform 0.2s ease-out, box-shadow 0.18s ease;
    }
    .timeline-card-wrap:hover #timeline {
      transform: translate(-2px, -2px);
      box-shadow: 0 6px 18px rgba(0,0,0,.08);
    }
    body:has(#view-math:checked)  #timeline { border-left-color: #6ba3e8; --card-tint: var(--subj-math); }
    body:has(#view-comp:checked)  #timeline { border-left-color: #9b7ed8; --card-tint: var(--subj-comp); }
    body:has(#view-phys:checked)  #timeline { border-left-color: #e8915a; --card-tint: var(--subj-phys); }
    body:has(#view-chem:checked)  #timeline { border-left-color: #8db849; --card-tint: var(--subj-chem); }
    body:has(#view-bio:checked)   #timeline { border-left-color: #5bbfb0; --card-tint: var(--subj-bio); }
    body:has(#view-astro:checked) #timeline { border-left-color: #e86088; --card-tint: var(--subj-astro); }

    .timeline { padding-left: 0; margin-left: 0; }
    .timeline .year-marker {
      font-weight: 700; font-size: 1.1em;
      margin: 1.2em 0 .4em 0;
      /* Flush-align the year with the month column below it. .entry has
         font-size: .95em + padding-left: .6em → ~0.57em parent-relative.
         Year-marker is 1.1em, so we scale down to (.95/1.1)*.6 ≈ .52em
         to land on the same absolute x-offset. */
      padding-left: .52em;
      display: inline-block;
    }
    .timeline .entry {
      display: grid;
      grid-template-columns: 6.5em 1.8em auto 1fr;
      gap: 0 .5em;
      padding: .35em .6em;
      position: relative;
      font-size: .95em;
      align-items: first baseline;
    }
    .timeline .entry .top-line { display: contents; }
    .timeline .entry .month { color: #656d76; font-variant-numeric: tabular-nums; }
    .timeline .entry .type-cell { text-align: center; }
    .timeline .entry .chips-cell { white-space: nowrap; display: flex; gap: 2px; align-items: center; }
    .timeline .entry .name-cell { }
    .status-emoji {
      font-size: 1em;
      margin-left: .3em;
      position: relative;
      display: inline-block;
      vertical-align: middle;
      cursor: default;
    }
    .status-emoji .glyph,
    .photo-icon .glyph {
      display: inline-block;
      position: relative;
      overflow: hidden;
    }
    .timeline .photo-icon { cursor: default; }
    .status-emoji-competitive { transform-origin: center 80%; }
    .status-emoji-competitive:hover,
    .timeline .entry:hover .status-emoji-competitive { animation: status-wiggle 0.55s ease; }
    @keyframes status-wiggle {
      0%   { transform: rotate(0); }
      20%  { transform: rotate(-15deg); }
      40%  { transform: rotate(12deg); }
      60%  { transform: rotate(-8deg); }
      80%  { transform: rotate(5deg); }
      100% { transform: rotate(0); }
    }
    .status-emoji-invited { position: relative; }
    .status-emoji-invited .glyph::after {
      content: '';
      position: absolute;
      inset: 0;
      background: linear-gradient(115deg, transparent 35%, rgba(255,255,255,0.85) 50%, transparent 65%);
      transform: translateX(-120%);
      pointer-events: none;
      mix-blend-mode: screen;
    }
    .status-emoji-invited:hover .glyph::after,
    .timeline .entry:hover .status-emoji-invited .glyph::after {
      animation: status-shimmer 1.0s ease-in-out;
    }
    @keyframes status-shimmer {
      from { transform: translateX(-120%); }
      to   { transform: translateX(120%); }
    }
    .timeline .entry.hl { position: relative; isolation: isolate; }
    .timeline .entry.hl::before {
      content: '';
      position: absolute;
      inset: 0;
      background-color: #fff44f;
      background-image: linear-gradient(100deg, transparent 0%, rgba(255,255,255,0.7) 50%, transparent 100%);
      background-size: 50% 100%;
      background-repeat: no-repeat;
      background-position: -100% 0;
      z-index: -1;
    }
    .timeline .entry.hl:hover::before { animation: hl-ripple 1.0s ease-out; }
    @keyframes hl-ripple {
      from { background-position: -60% 0; }
      to   { background-position: 200% 0; }
    }
    .foundation-badge {
      position: absolute;
      right: 0.6em;
      top: 50%;
      font-size: 0.6em;
      font-weight: 700;
      letter-spacing: 0.12em;
      background: #1f2328;
      color: #fff44f;
      padding: 0.25em 0.55em;
      border-radius: 3px;
      opacity: 0;
      pointer-events: none;
      transform: translate(-0.5em, -50%);
    }
    .timeline .entry.hl:hover .foundation-badge { animation: foundation-flash 1.0s ease-out; }
    @keyframes foundation-flash {
      0%   { opacity: 0; transform: translate(-0.5em, -50%); }
      20%  { opacity: 1; transform: translate(0, -50%); }
      70%  { opacity: 1; transform: translate(0, -50%); }
      100% { opacity: 0; transform: translate(0.5em, -50%); }
    }
    .timeline .entry { transition: background 0.15s ease; border-radius: 4px; }
    /* Hover shades the row in the active tab's science tint (deeper than
       the surrounding card wash) so the row visibly lifts inside its
       parent card without resorting to a neutral gray. Falls back to gray
       on the All tab where no card-tint is set. */
    .timeline .entry:hover {
      background: color-mix(in srgb, var(--card-tint, #d1d9e0) 35%, white);
    }

    .chip {
      display: inline-block;
      padding: 1px 7px;
      border-radius: 999px;
      font-size: .72em;
      font-weight: 600;
      color: #1f2328;
      vertical-align: middle;
      text-align: center;
      white-space: nowrap;
      line-height: 1.6;
    }
    .chip.math  { background: var(--subj-math); }
    .chip.comp  { background: var(--subj-comp); }
    .chip.phys  { background: var(--subj-phys); }
    .chip.chem  { background: var(--subj-chem); }
    .chip.bio   { background: var(--subj-bio); }
    .chip.astro { background: var(--subj-astro); }

    .type-icon { font-size: .85em; }
    .rings-icon { vertical-align: middle; }
    a.photo-icon, a.photo-icon:hover { color: inherit; text-decoration: none; }
    .photo-icon { font-size: .8em; margin-left: .3em; position: relative; display: inline-block; vertical-align: middle; overflow: hidden; }

    .legend { font-size: .82em; color: #656d76; margin: .3em 0 1em; line-height: 2; }
    .legend .chip { margin-right: .3em; }

    @media (max-width: 600px) {
      .tabs .tab-labels label { padding: 0.45em 0.7em; font-size: 0.8em; }
      .timeline .entry {
        display: flex;
        flex-direction: column;
        gap: .15em;
        padding: .5em .7em;
      }
      .timeline .entry .top-line {
        display: flex;
        align-items: center;
        gap: .35em;
        flex-wrap: wrap;
      }
      .timeline .entry .month { display: inline; font-size: .82em; }
      .timeline .entry .month:empty { display: none; }
      .timeline .entry .type-cell { display: inline; text-align: left; margin: 0 .2em; }
      .timeline .entry .chips-cell { display: inline-flex; }
      .timeline .entry .name-cell { font-size: .95em; line-height: 1.4; }
    }
  </style>

  <script is:inline>
  // Timeline view — renders archives/truth/olympiads.json as a vertical
  // chronological timeline grouped by year.
  (function () {
    var SUBJECT_SLUGS = {
      Mathematics: 'math', Computing: 'comp', Physics: 'phys',
      Chemistry: 'chem', Biology: 'bio', Astronomy: 'astro'
    };
    function esc(s) {
      return String(s).replace(/[&<>"']/g, function (c) {
        return { '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;' }[c];
      });
    }

    function chip(subj) {
      var slug = SUBJECT_SLUGS[subj];
      return '<a class="chip ' + slug + '" href="/olympiads/#' + slug + '">' + subj + '</a>';
    }

    function chipsForEntry(e) {
      var subjects = e.subjects || [e.subject];
      return subjects.map(chip).join('');
    }

    function renderTimeline(items, filter) {
      var filtered = filter === 'all'
        ? items
        : items.filter(function (e) {
            var subjects = e.subjects || [e.subject];
            return subjects.some(function (s) { return SUBJECT_SLUGS[s] === filter; });
          });

      filtered.sort(function (a, b) { return b.sort_key.localeCompare(a.sort_key); });

      var years = {};
      var yearOrder = [];
      filtered.forEach(function (e) {
        var y = e.sort_key === '9999-12' ? 'Future' : e.sort_key.slice(0, 4);
        if (!years[y]) { years[y] = []; yearOrder.push(y); }
        years[y].push(e);
      });

      var html = '<div class="timeline">';
      var entryIdx = 0;
      yearOrder.forEach(function (y, yi) {
        html += '<div class="year-marker fade-in" style="animation-delay:' + (yi * 0.04).toFixed(2) + 's">' + y + '</div>';
        years[y].forEach(function (e) {
          var month = e.date === 'Future' ? '' : e.date.split(' ')[0];
          var icon = e.type === 'olympiad'
            ? '<svg class="rings-icon" viewBox="0 0 50 24" width="20" height="10"><circle cx="8" cy="8" r="6" fill="none" stroke="#0081C8" stroke-width="1.5"/><circle cx="18" cy="8" r="6" fill="none" stroke="#000" stroke-width="1.5"/><circle cx="28" cy="8" r="6" fill="none" stroke="#EE334E" stroke-width="1.5"/><circle cx="13" cy="14" r="6" fill="none" stroke="#FCB131" stroke-width="1.5"/><circle cx="23" cy="14" r="6" fill="none" stroke="#00A651" stroke-width="1.5"/></svg>'
            : '<span class="type-icon">📖</span>';
          var cls = e.highlighted ? ' hl' : '';
          var delay = (0.05 + entryIdx * 0.025).toFixed(2);
          entryIdx++;
          html += '<div class="entry fade-in' + cls + '" data-subject="' + SUBJECT_SLUGS[e.subject] + '" style="animation-delay:' + delay + 's">'
            + '<div class="top-line">'
            + '<div class="month">' + month + '</div>'
            + '<div class="type-cell">' + icon + '</div>'
            + '<div class="chips-cell">' + chipsForEntry(e) + '</div>'
            + '</div>'
            + '<div class="name-cell">' + esc(e.name) + (e.invited ? ' <span class="status-emoji status-emoji-invited"><span class="glyph">🎟️</span></span>' : '') + (e.borderline ? ' <span class="status-emoji status-emoji-competitive"><span class="glyph">🎯</span></span>' : '') + (e.competitive ? ' <span class="status-emoji status-emoji-competitive"><span class="glyph">🎯</span></span>' : '') + (e.photo_url ? ' <a class="photo-icon" href="' + e.photo_url + '" title="View photo"><span class="glyph">📷</span></a>' : '') + '</div>'
            + (e.highlighted ? '<span class="foundation-badge">FOUNDATION</span>' : '')
            + '</div>';
        });
      });
      html += '</div>';

      document.getElementById('timeline').innerHTML = html;
    }

    fetch('/olympiads/olympiads.json', { cache: 'no-cache' })
      .then(function (r) { if (!r.ok) throw new Error(r.status); return r.json(); })
      .then(function (d) {
        var items = d.items;
        var checked = document.querySelector('input[name="view"]:checked');
        var filter = checked ? checked.id.replace('view-', '') : 'all';
        renderTimeline(items, filter);
        var radios = document.querySelectorAll('input[name="view"]');
        radios.forEach(function (radio) {
          radio.addEventListener('change', function () {
            var filter = this.id.replace('view-', '');
            sessionStorage.setItem('subj-tab', filter);
            renderTimeline(items, filter);
          });
        });
      });
  })();
  </script>

  <hr />

  <PageFooter active="olympiads" />
</DefaultLayout>
