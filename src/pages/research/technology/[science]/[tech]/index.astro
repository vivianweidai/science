---
import { getCollection, render } from 'astro:content';
import DefaultLayout from '../../../../../layouts/Default.astro';
import PageHeader from '../../../../../layouts/PageHeader.astro';
import PageFooter from '../../../../../layouts/PageFooter.astro';
import techData from '../../../../../../public/research/technology.json';

export async function getStaticPaths() {
  const techs = await getCollection('tech');
  return techs.map((entry) => {
    // id is "<science_folder>/<Tech Name>", e.g. "chemistry/IR Spectroscopy".
    const [science, tech] = entry.id.split('/');
    return {
      params: { science, tech },
      props: { entry },
    };
  });
}

const { entry } = Astro.props;
const { Content } = await render(entry);
const { tech, science, science_slug, topic, category, hero, hero_position } = entry.data;

// Tech spec text comes from technology.json (built from technology.yml —
// single source of truth for tech text).
let specs = '';
for (const t of techData.topics) {
  if (t.science_slug !== science_slug || t.topic !== topic) continue;
  for (const cat of t.categories) {
    if (cat.category !== category) continue;
    for (const tt of cat.techs) {
      if (tt.tech === tech) specs = tt.specs;
    }
  }
}
const slug = (s: string) => s.toLowerCase().replace(/\s+/g, '-');
const topicSlug = slug(topic);
const catSlug = slug(category);

// Reverse-lookup every project that uses this tech. Source of truth is
// each project's `tech:` frontmatter array.
const projects = await getCollection('projects');
const matched = projects.filter((p) => (p.data.tech ?? []).includes(tech));

const MONTHS = ['January','February','March','April','May','June',
                'July','August','September','October','November','December'];
function ordinal(d: number): string {
  const j = d % 10, k = d % 100;
  if (j === 1 && k !== 11) return d + 'st';
  if (j === 2 && k !== 12) return d + 'nd';
  if (j === 3 && k !== 13) return d + 'rd';
  return d + 'th';
}

type ProjRow = {
  sortKey: string;        // YYYYMMDD for chronological sort, newest first
  href: string;           // local /research/... or external https://...
  date: string;           // human-formatted ("April 27th 2026")
  title: string;
  chips: { slug: string; label: string }[];
};
const projList: ProjRow[] = [];

// Title + chips both come from project frontmatter — no more regex parsing
// of the markdown body's <div class="project-title">…</div> block.
const SCIENCE_SHORT: Record<string, string> = {
  Mathematics: 'math', Computing: 'comp', Physics: 'phys',
  Chemistry: 'chem', Biology: 'bio', Astronomy: 'astro',
};

for (const proj of matched) {
  const folder = proj.id;
  const m = folder.match(/^(\d{4})(\d{2})(\d{2})/);
  if (!m) continue;
  const date = `${MONTHS[parseInt(m[2]) - 1]} ${m[1]}`;
  const chips = (proj.data.sciences ?? [])
    .map((s) => ({ slug: SCIENCE_SHORT[s] ?? '', label: s }))
    .filter((c) => c.slug);
  projList.push({
    sortKey: m[1] + m[2] + m[3],
    href: `/research/projects/${encodeURIComponent(folder)}/`,
    date,
    title: proj.data.title,
    chips,
  });
}

projList.sort((a, b) => b.sortKey.localeCompare(a.sortKey));

// Resolve hero path. Frontmatter usually has a relative path like
// `numpy.jpeg`; turn it into an absolute URL the browser can fetch.
// Uses the route's folder param (full science name, e.g. "mathematics") —
// not science_slug (short, "math"), which is for chip styling only.
const scienceFolder = Astro.params.science!;
function resolveHero(h: string | undefined, folder: string, name: string): string | null {
  if (!h) return null;
  if (h.startsWith('/') || h.startsWith('http://') || h.startsWith('https://')) return h;
  return `/research/technology/${folder}/${encodeURIComponent(name)}/${h.split('/').map(encodeURIComponent).join('/')}`;
}
const heroUrl = resolveHero(hero, scienceFolder, tech);

// ----- Cross-tech prev/next nav -----
// Flatten technology.yml's topic → category → tech hierarchy into a single
// canonical sequence so prev/next can cycle through every tech on the
// site (and roll over from one science's last tech into the next
// science's first). Only techs with a template page (tech_url present)
// are included — placeholder techs without pages would dead-end the nav.
type FlatTech = {
  tech: string;
  tech_url: string;
  topic: string;
  science: string;
  science_slug: string;
};
const flatTechs: FlatTech[] = [];
for (const t of techData.topics) {
  for (const cat of t.categories) {
    for (const tt of cat.techs) {
      if (!tt.tech_url) continue;
      flatTechs.push({
        tech: tt.tech,
        tech_url: tt.tech_url,
        topic: t.topic,
        science: t.science,
        science_slug: t.science_slug,
      });
    }
  }
}
const currentIdx = flatTechs.findIndex(
  (ft) => ft.tech === tech && ft.science_slug === science_slug,
);
// Wrap around at the ends so prev on the very first tech lands on the
// last, and next on the very last tech lands on the first.
const N = flatTechs.length;
const prevTech = currentIdx >= 0 && N > 1 ? flatTechs[(currentIdx - 1 + N) % N] : null;
const nextTech = currentIdx >= 0 && N > 1 ? flatTechs[(currentIdx + 1) % N] : null;

// Topic is intentionally not included in the nav since it has no landing
// page — only Tech and the Science chip get rendered. crossScience drives
// whether the chip appears at all.
function navMeta(target: FlatTech | null) {
  if (!target) return null;
  return {
    ...target,
    crossScience: target.science_slug !== science_slug,
  };
}
const prevMeta = navMeta(prevTech);
const nextMeta = navMeta(nextTech);
---
<DefaultLayout title={`${tech} — ${science}`}>
  <PageHeader title="Research" researchHref={`/research/#${science_slug}`} />

  <div class="tech-prevnext" data-prev-href={prevMeta?.tech_url} data-next-href={nextMeta?.tech_url} data-back-href={`/research/#${science_slug}`}>
    {prevMeta ? (
      <span class="tech-prevnext-side prev">
        <span class="tech-prevnext-arrow">←</span>
        <a href={prevMeta.tech_url}>{prevMeta.tech}</a>
        {prevMeta.crossScience && (<>
          <span class="tech-prevnext-sep">·</span>
          <a class={`chip ${prevMeta.science_slug}`} href={`/research/#${prevMeta.science_slug}`}>{prevMeta.science}</a>
        </>)}
      </span>
    ) : (<span class="tech-prevnext-side spacer">←</span>)}
    {nextMeta ? (
      <span class="tech-prevnext-side next">
        {nextMeta.crossScience && (<>
          <a class={`chip ${nextMeta.science_slug}`} href={`/research/#${nextMeta.science_slug}`}>{nextMeta.science}</a>
          <span class="tech-prevnext-sep">·</span>
        </>)}
        <a href={nextMeta.tech_url}>{nextMeta.tech}</a>
        <span class="tech-prevnext-arrow">→</span>
      </span>
    ) : (<span class="tech-prevnext-side spacer">→</span>)}
  </div>

  <div class="tech-page-wrap">
  <article class={`tech-page tech-accent-${science_slug} card-pop-in`}>
    <div class="tech-title">
      <h1>{tech}{specs && (
        <span class="tech-specs-inline">{specs}</span>
      )}</h1>
      <span class="tech-context">
        <a class="tech-context-link" href={`/research/#${science_slug}/${topicSlug}/${catSlug}`}>{category}</a>
        <span class="tech-context-sep"> · </span>
        <a class="tech-context-link" href={`/research/#${science_slug}/${topicSlug}`}>{topic}</a>
        <span class="tech-context-sep"> · </span>
        <a class={`chip ${science_slug}`} href={`/research/#${science_slug}`}>{science}</a>
      </span>
    </div>
    {heroUrl && (
      <div class="hero-single">
        <img src={heroUrl} alt={tech} style={hero_position ? `object-position: ${hero_position};` : undefined} />
      </div>
    )}

    {entry.data.toys && entry.data.toys.length > 0 && (
      <>
        <h2>Toys</h2>
        <ul class="updates-list toy-list">
          {entry.data.toys.map((toy) => (
            <li data-subj={science_slug}>
              <span class="update-body">
                <span class="toy-name">{toy.name}</span>
                <span class="toy-desc">{toy.description}</span>
              </span>
            </li>
          ))}
        </ul>
      </>
    )}

    <Content />

    <h2>Projects</h2>
    {projList.length === 0 ? (
      <p class="tech-no-projects">No projects yet.</p>
    ) : (
      <ul class="updates-list">
        {projList.map((p) => (
          <li data-subj={p.chips[0]?.slug ?? ''}>
            <span class="update-date">{p.date}</span>
            <span class="update-body">
              <a href={p.href}>{p.title}</a>
              {p.chips.map((c) => (
                <a class={`chip ${c.slug}`} href={`/research/#${c.slug}`}>{c.label}</a>
              ))}
            </span>
          </li>
        ))}
      </ul>
    )}
  </article>
  </div>

  <hr />

  <PageFooter researchHref={`/research/#${science_slug}`} />

  <style is:global>
    /* Title row: H1 + science chip on the left, topic · category on the
       right. Single border-bottom on the row itself spans the full body
       width — H1's own underline is suppressed so the divisor doesn't end
       at the title text. align-items: center keeps the chip vertically
       centered with the H1. */
    /* Tech page reads as a "spec sheet card" — distinct from the
       project-page document layout. Mirrors the /research/ topic
       cards: 1 px gray border + 4 px science-colored left accent +
       a very soft science-tinted wash so the page signals "you're
       on a reference card" at a glance. */
    /* Cross-tech prev/next nav — sits OUTSIDE the .tech-page-wrap card,
       above and below it. Each side packs three independently-clickable
       parts (tech · topic · science chip) separated by middle dots, with
       the arrow as a non-interactive cap. Mirrors .curr-prevnext. */
    .tech-prevnext {
      display: flex;
      justify-content: space-between;
      align-items: center;
      gap: 1em;
      font-size: 0.9em;
    }
    .tech-prevnext-side {
      display: inline-flex;
      align-items: center;
      gap: 0.4em;
      flex-wrap: wrap;
      max-width: 48%;
      line-height: 1.5;
    }
    .tech-prevnext-side.next { justify-content: flex-end; }
    .tech-prevnext-side a {
      color: #0969da;
      text-decoration: none;
      font-weight: 400;
    }
    .tech-prevnext-side a:hover { text-decoration: underline; }
    .tech-prevnext-side a.chip:hover { text-decoration: none; }
    .tech-prevnext-arrow { color: #0969da; }
    .tech-prevnext-sep   { color: #1f2328; opacity: 0.4; }
    .tech-prevnext-side.spacer { visibility: hidden; }
    .tech-prevnext { margin: 1.5em 0; }

    /* Hover hit-region wrapper — 2 px of bottom/right padding catches the
       cursor when the article lifts up-and-left on hover (same trick as
       .tech-card-wrap). */
    .tech-page-wrap {
      margin: 0;
      padding: 0 2px 2px 0;
    }
    .tech-page {
      border: 1px solid #d1d9e0;
      border-left: 4px solid #d1d9e0;
      border-radius: 8px;
      padding: 1em 1.4em 1.4em;
      background: color-mix(in srgb, var(--card-tint, #d1d9e0) 18%, white);
      transition: transform 0.2s ease-out, box-shadow 0.18s ease;
    }
    .tech-page-wrap:hover .tech-page {
      transform: translate(-2px, -2px);
      box-shadow: 0 6px 18px rgba(0,0,0,.08);
    }
    .tech-page.tech-accent-math  { border-left-color: #6ba3e8; --card-tint: var(--subj-math); }
    .tech-page.tech-accent-comp  { border-left-color: #9b7ed8; --card-tint: var(--subj-comp); }
    .tech-page.tech-accent-phys  { border-left-color: #e8915a; --card-tint: var(--subj-phys); }
    .tech-page.tech-accent-chem  { border-left-color: #8db849; --card-tint: var(--subj-chem); }
    .tech-page.tech-accent-bio   { border-left-color: #5bbfb0; --card-tint: var(--subj-bio); }
    .tech-page.tech-accent-astro { border-left-color: #e86088; --card-tint: var(--subj-astro); }

    .tech-page .tech-title {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 1em;
      flex-wrap: wrap;
      margin: .2em 0 .8em 0;
    }
    .tech-page .tech-title h1 {
      font-size: 1.6em;
      margin: 0;
      border-bottom: none;
      padding-bottom: 0;
    }
    .tech-page .tech-title h1 .tech-specs-inline {
      font-weight: 400;
      font-size: 0.65em;
      color: #656d76;
      margin-left: 0.5em;
      vertical-align: baseline;
    }
    .tech-page .tech-context {
      display: inline-flex;
      align-items: center;
      gap: .35em;
      color: #656d76;
      font-size: .92em;
      white-space: nowrap;
    }
    .tech-page .tech-context .chip {
      margin-right: .15em;
    }

    /* Topic/category links in the title row — quiet styling, deep-link
       into /research/ at the matching section. */
    .tech-page .tech-context-link {
      color: inherit;
      text-decoration: none;
    }
    .tech-page .tech-context-link:hover { text-decoration: underline; }

    /* Hero — same dimensions as the research project pages so a tech page
       and a project page read at the same scale. Border + drop shadow let
       mostly-white screenshots (NumPy code, etc.) sit visually separate
       from the white page background. */
    .tech-page .hero-single img {
      width: 100%;
      height: 250px;
      object-fit: cover;
      border-radius: 6px;
      border: 1px solid #d1d9e0;
      box-shadow: 0 4px 18px rgba(0, 0, 0, .12), 0 1px 3px rgba(0, 0, 0, .08);
      margin: 1em 0 .5em 0;
      display: block;
    }

    .tech-page h2 {
      font-size: 1.05em;
      margin-top: 1.6em;
      border-bottom: none;
      padding-bottom: 0;
    }

    .tech-page .tech-no-projects {
      color: #8c959f;
      font-style: italic;
    }

    /* Projects list — homepage updates-list format. Scoped to .tech-page
       so it doesn't leak into other consumers; rules mirror /index.astro's
       .updates-list. */
    .tech-page .updates-list {
      list-style: none;
      padding: 0;
      margin: 1em 0 0;
      border: 1px solid #d1d9e0;
      border-radius: 10px;
      overflow: hidden;
      background: #fff;
    }
    .tech-page .updates-list li {
      display: flex;
      gap: 1em;
      align-items: baseline;
      padding: 0.55em 1em 0.55em 1.4em;
      border-bottom: 1px solid #eaecef;
      line-height: 1.6;
      position: relative;
      transition: background 0.15s ease;
    }
    .tech-page .updates-list li:last-child { border-bottom: none; }
    .tech-page .updates-list li:nth-child(even) { background: #f6f8fa; }
    .tech-page .updates-list li:hover { background: #eef1f4; }
    .tech-page .updates-list li::before {
      content: '';
      position: absolute;
      left: 0; top: 0; bottom: 0;
      width: 5px;
      background: var(--accent, #d1d9e0);
    }
    .tech-page .updates-list li[data-subj="math"]  { --accent: var(--subj-math); }
    .tech-page .updates-list li[data-subj="comp"]  { --accent: var(--subj-comp); }
    .tech-page .updates-list li[data-subj="phys"]  { --accent: var(--subj-phys); }
    .tech-page .updates-list li[data-subj="chem"]  { --accent: var(--subj-chem); }
    .tech-page .updates-list li[data-subj="bio"]   { --accent: var(--subj-bio); }
    .tech-page .updates-list li[data-subj="astro"] { --accent: var(--subj-astro); }
    .tech-page .updates-list .update-date {
      flex-shrink: 0;
      min-width: 9em;
      color: #656d76;
      font-size: 0.9em;
    }
    .tech-page .updates-list .update-body { flex: 1; }
    .tech-page .updates-list .chip { margin-left: 0.9em; }
    .tech-page .updates-list .chip + .chip { margin-left: 0.9em; }
    /* Toys list: each row is name (or link) — description on one line.
       Grid lives on the <ul> so every row shares column widths; the <li>
       and inner <span> use subgrid + display:contents to participate in
       the same two columns. The first column auto-sizes to the longest
       toy name on the page. */
    .tech-page .toy-list {
      display: grid;
      grid-template-columns: max-content 1fr;
    }
    .tech-page .toy-list li {
      display: grid;
      grid-template-columns: subgrid;
      grid-column: 1 / -1;
      column-gap: 1.5em;
      align-items: baseline;
    }
    .tech-page .toy-list .update-body {
      display: contents;
    }
    .tech-page .toy-list .toy-name,
    .tech-page .toy-list .update-body > a {
      font-weight: 500;
    }
    .tech-page .toy-list .toy-desc {
      color: #57606a;
      font-size: 0.92em;
    }
    @media (max-width: 600px) {
      .tech-page .toy-list { grid-template-columns: 1fr; }
      .tech-page .toy-list li { row-gap: 0.15em; }
    }
    @media (max-width: 600px) {
      .tech-page .updates-list .update-date { display: none; }
    }
  </style>

  <script is:inline>
    // Keyboard shortcuts: ← → cycle through techs; Esc returns to the
    // science's /research/ section. Hrefs are baked into .tech-prevnext
    // data attributes. Skipped when the user is typing in a form field
    // or holding a modifier key.
    (function () {
      var nav = document.querySelector('.tech-prevnext');
      if (!nav) return;
      document.addEventListener('keydown', function (e) {
        if (e.key !== 'ArrowLeft' && e.key !== 'ArrowRight' && e.key !== 'Escape') return;
        if (e.metaKey || e.ctrlKey || e.altKey || e.shiftKey) return;
        var t = e.target;
        if (t && (t.tagName === 'INPUT' || t.tagName === 'TEXTAREA' || t.isContentEditable)) return;
        var href;
        if (e.key === 'ArrowLeft') href = nav.dataset.prevHref;
        else if (e.key === 'ArrowRight') href = nav.dataset.nextHref;
        else href = nav.dataset.backHref;
        if (!href) return;
        e.preventDefault();
        window.location.href = href;
      });
    })();
  </script>
</DefaultLayout>
