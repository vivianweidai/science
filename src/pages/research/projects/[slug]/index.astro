---
import { getCollection, render } from 'astro:content';
import { readdirSync, statSync, existsSync } from 'node:fs';
import { join, relative } from 'node:path';
import ProjectLayout from '../../../../layouts/Project.astro';

export async function getStaticPaths() {
  const projects = await getCollection('projects');

  return projects.map((entry) => {
    // generateId in content.config.ts preserves the original folder name as id.
    const folder = entry.id;

    // Discover photos under public/research/projects/<folder>/photos/, excluding photos/data/.
    // Photos serve at /research/projects/<folder>/photos/... (Astro public/ → URL root).
    const photosRoot = join(process.cwd(), 'public', 'research', 'projects', folder, 'photos');
    const photos: string[] = [];
    if (existsSync(photosRoot)) {
      const walk = (dir: string) => {
        for (const name of readdirSync(dir)) {
          const full = join(dir, name);
          const st = statSync(full);
          if (st.isDirectory()) {
            // Skip photos/data/ — data sheets are surfaced separately, not in shuffle.
            if (relative(photosRoot, full) === 'data') continue;
            walk(full);
          } else if (/\.(jpg|jpeg|png)$/i.test(name)) {
            // Absolute URL since file path (under /content/) differs from page URL (/research/projects/<folder>/).
            photos.push(`/research/projects/${folder}/photos/` + relative(photosRoot, full));
          }
        }
      };
      walk(photosRoot);
    }

    return {
      params: { slug: folder },
      props: { entry, photos },
    };
  });
}

const { entry, photos } = Astro.props;
const { Content } = await render(entry);
---
<ProjectLayout
  project={entry.data.project}
  title={entry.data.title}
  sciences={entry.data.sciences}
  mi={entry.data.mi}
  photos={photos}
>
  <Content />
</ProjectLayout>
